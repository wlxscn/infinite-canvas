{
  "name": "infinite-canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @infinite-canvas/web --filter @infinite-canvas/agent-api dev",
    "dev:web": "pnpm --filter @infinite-canvas/web dev",
    "dev:api": "pnpm --filter @infinite-canvas/agent-api dev",
    "dev:browser-use": "node scripts/browser-use-stack.mjs",
    "build": "pnpm --parallel --filter @infinite-canvas/web --filter @infinite-canvas/agent-api build",
    "build:web": "pnpm --filter @infinite-canvas/web build",
    "build:api": "pnpm --filter @infinite-canvas/agent-api build",
    "lint": "pnpm --parallel --filter @infinite-canvas/web --filter @infinite-canvas/agent-api lint",
    "lint:web": "pnpm --filter @infinite-canvas/web lint",
    "lint:api": "pnpm --filter @infinite-canvas/agent-api lint",
    "test": "pnpm --filter @infinite-canvas/web test",
    "test:e2e": "pnpm --filter @infinite-canvas/web test:e2e",
    "preview": "pnpm --filter @infinite-canvas/web preview"
  }
}
