# Shared
NODE_ENV=development

# Web
VITE_AGENT_API_URL=http://127.0.0.1:8787/chat

# Agent API
PORT=8787
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Supabase project persistence is optional for local development.
# If omitted, the web app keeps using localStorage as a fallback cache.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
