# Shared
NODE_ENV=development

# Web
VITE_AGENT_API_URL=http://127.0.0.1:8787/chat

# Agent API
PORT=8787
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
AI_GATEWAY_API_KEY=
VERCEL_OIDC_TOKEN=
VERCEL_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
VERCEL_AI_GATEWAY_MODEL=openai/gpt-5.4
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Cloudflare R2 generated media storage.
# Generated image/video endpoints require these values before returning completed media.
# Configure the bucket or custom domain CORS to allow the web origins above to read media.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
CLOUDFLARE_R2_KEY_PREFIX=generated
GENERATED_MEDIA_MAX_BYTES=262144000
GENERATED_MEDIA_FETCH_TIMEOUT_MS=60000
GENERATED_MEDIA_CACHE_CONTROL=public, max-age=31536000, immutable

# Supabase project persistence is optional for local development.
# If omitted, the web app keeps using localStorage as a fallback cache.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
